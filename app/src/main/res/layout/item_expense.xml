<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView  xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardExpenseItem"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="?attr/colorSurface">

    <!--
        MaterialCardView:
        Gives each expense entry a rounded card appearance
        with a subtle shadow beneath it.

        cardBackgroundColor="?attr/colorSurface"
        Uses the theme surface colour — automatically white
        in light mode and dark grey in dark mode. Never
        hardcode white (#FFFFFF) here or dark mode breaks.

        android:id="@+id/cardExpenseItem"
        The adapter uses this ID to attach click listeners
        for tap (view detail) and long press (delete).
    -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">

        <!--
            Horizontal LinearLayout — children sit side by side:
            [Category Icon Circle]  [Expense Details]  [Receipt Icon]

            gravity="center_vertical" keeps all three sections
            vertically centred relative to each other even if
            the middle details section is taller than the icon.
        -->

        <!--
             LEFT: CATEGORY ICON WITH COLOURED CIRCLE
             FrameLayout stacks children on top of each other.
             The circle View sits at the bottom layer.
             The icon ImageView sits centred on top of it.
              -->
        <FrameLayout
            android:layout_width="46dp"
            android:layout_height="46dp">

            <!--
                THE COLOURED CIRCLE
                This is the oval shape from circle_background.xml.
                Its colour is set at runtime by the adapter:
                vCategoryIconBackground.backgroundTintList =
                    ColorStateList.valueOf(Color.parseColor(category.color))
            -->
            <View
                android:id="@+id/vCategoryIconBackground"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:background="@drawable/circle_background"/>

            <!--
                THE CATEGORY ICON
                Sits centred on top of the circle.
                Set by the adapter based on category.iconName.
                layout_gravity="center" centres it inside
                the 46dp x 46dp FrameLayout.
            -->
            <ImageView
                android:id="@+id/ivCategoryIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/icon_category"
                android:contentDescription="Category icon"/>

        </FrameLayout>

    <!--
         MIDDLE: EXPENSE TEXT DETAILS
         layout_width="0dp" + layout_weight="1" makes
         this column take ALL remaining horizontal space
         between the icon (46dp) and receipt icon (20dp).
         Four rows: category name, amount, date, description.
          -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="8dp">

        <!--
                CATEGORY NAME
                e.g. "Entertainment", "Food", "Transport"
                Bold — the primary label for the expense.
                Set by adapter: tvExpenseCategoryName.text = category.name
            -->
        <TextView
            android:id="@+id/tvExpenseCategoryName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Category Name"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSurface"/>

        <!--
                ENTRY AMOUNT
                e.g. "R 383" or "R 250.00"
                Formatted by adapter: "R %.2f".format(expense.amount)
                colorPrimary makes the amount stand out visually.
                Per mockup: amount shows on same line area as name.
            -->
        <TextView
            android:id="@+id/tvExpenseAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="R 0.00"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="?attr/colorPrimary"
            android:layout_marginTop="2dp"/>

        <!--
                DATE ADDED
                e.g. "Date Added: 12-05-2026"
                Adapter formats the stored Long timestamp:
                "Date Added: " + SimpleDateFormat("dd-MM-yyyy").format(date)
                colorOnSurfaceVariant = muted secondary text colour.
            -->
        <TextView
            android:id="@+id/tvExpenseDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Date Added: --"
            android:textSize="12sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:layout_marginTop="2dp"/>

        <!--
                DESCRIPTION
                e.g. "Netflix Subscription", "Lunch at Nandos"
                Optional — may be empty string.
                maxLines="1" + ellipsize="end" truncates long text:
                "Lunch at the new restaurant in Sand..."
            -->
        <TextView
            android:id="@+id/tvExpenseDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Description"
            android:textSize="12sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:layout_marginTop="2dp"
            android:maxLines="1"
            android:ellipsize="end"/>

    </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>