<?xml version="1.0" encoding="utf-8"?>

<!--
    WHAT THIS FILE IS:
    Full screen layout for the Expenses HOME screen.
    This is the default landing screen after login per
    the design doc section 4.2.1.
    -->

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorBackground">

    <!--
        Root LinearLayout: vertical orientation means every
        child stacks top to bottom filling the full screen.
    -->

    <!--
         HEADER ROW
         Left: screen title "EXPENSES"
         Right: FROM and TO date filter buttons
         Matches the top bar visible in the UI mockup.
          -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:background="?attr/colorSurface"
        android:elevation="4dp">

        <!--
            elevation="4dp": header bar casts a shadow over
            the list below it — creates clear visual separation
            between the fixed header and scrolling content.
        -->

        <!--
            SCREEN TITLE
            layout_weight="1" pushes the date buttons to the right.
        -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="EXPENSES"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSurface"/>

        <!--
            FROM DATE LABEL + BUTTON
            Tapping btnDateFrom opens a MaterialDatePicker
            in the Activity. The Activity updates the button
            text with the selected date.
        -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FROM"
            android:textSize="11sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:layout_marginEnd="4dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDateFrom"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="10-06-2026"
            android:textSize="11sp"
            android:layout_marginEnd="8dp"/>

        <!--
            TO DATE LABEL + BUTTON
            Same behaviour as FROM button above.
        -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TO"
            android:textSize="11sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:layout_marginEnd="4dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDateTo"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="10-07-2026"
            android:textSize="11sp"/>

    </LinearLayout>

    <!--
         SORT RADIO BUTTONS
         Three options per UI mockup: A-Z, First Added, Last Added.
         HorizontalScrollView wraps them so they scroll on
         narrow screens without getting cut off.

         When the user selects a button, the Activity calls:
         viewModel.setSortOrder(SortOrder.AZ) etc.
         The StateFlow re-sorts and the adapter updates.
          -->

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:background="?attr/colorSurface"
        android:paddingBottom="8dp">

        <RadioGroup
            android:id="@+id/rgSortOrder"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp">

            <!--
                RadioGroup: only ONE option can be selected at
                a time. Selecting "Last Added" automatically
                deselects "A-Z" — built into RadioGroup.
            -->

            <!--
                SORT OPTION 1: Alphabetical
                checked="true" = default selection on screen open.
            -->
            <RadioButton
                android:id="@+id/rbSortAZ"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="A-Z"
                android:checked="true"
                android:textSize="13sp"/>

            <!--
                SORT OPTION 2: Oldest expense first
            -->
            <RadioButton
                android:id="@+id/rbSortFirstAdded"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="First Added"
                android:layout_marginStart="8dp"
                android:textSize="13sp"/>

            <!--
                SORT OPTION 3: Newest expense first
                Most useful for users who want to see
                their most recent expenses at the top.
            -->
            <RadioButton
                android:id="@+id/rbSortLastAdded"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Last Added"
                android:layout_marginStart="8dp"
                android:textSize="13sp"/>

        </RadioGroup>
    </HorizontalScrollView>

    <!-- Thin visual divider between sort controls and the list -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/colorOutlineVariant"/>

    <!--
         EMPTY STATE MESSAGE
         Shown when the user has no expenses logged yet.
         Hidden when the list has items.

         The Activity controls this:
         if (list.isEmpty()) {
             tvEmptyState.visibility = View.VISIBLE
             rvExpenses.visibility = View.GONE
         } else {
             tvEmptyState.visibility = View.GONE
             rvExpenses.visibility = View.VISIBLE
         }
          -->
    <TextView
        android:id="@+id/tvEmptyState"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="No expenses yet.\nTap Add Expense below to get started."
        android:textAlignment="center"
        android:gravity="center"
        android:textSize="15sp"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:padding="40dp"
        android:visibility="gone"/>
    <!--
        layout_height="0dp" + layout_weight="1":
        When visible, it fills all space between the sort
        bar and Add button — the message is centred on screen.
        visibility="gone" = hidden by default, zero space used.
    -->

    <!--
         EXPENSE LIST (RecyclerView)
         Each row is one instance of item_expense.xml
         inflated by ExpenseAdapter.kt.

         layout_height="0dp" + layout_weight="1":
         Fills ALL vertical space between the sort controls
         above and the Add Expense button below.

         clipToPadding="false":
         Allows the last expense card to scroll up above the
         Add button's padding area so it is never hidden
         behind the button when scrolled to the very bottom.
          -->

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvExpenses"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false"/>
    
    <!--
        The Activity must set a LayoutManager in code or
        the list will not display anything:
        rvExpenses.layoutManager = LinearLayoutManager(this)
        rvExpenses.adapter = expenseAdapter
    -->

</LinearLayout>