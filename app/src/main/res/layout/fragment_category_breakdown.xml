<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:text="Category Breakdown"
        android:textAllCaps="true"
        android:gravity="center"
        android:textSize="18sp"
        android:layout_weight="100"/>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="horizontal"
        android:layout_weight="200">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SORT BY"/>

        <RadioGroup
            android:id="@+id/rgCategorySort"
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            >

            <RadioButton
                android:id="@+id/rbCategorySortAZ"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="A - Z" />

            <RadioButton
                android:id="@+id/rbCategorySortLastUsed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Last Used" />

            <RadioButton
                android:id="@+id/rbCategorySortMostUsed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Most Used" />
        </RadioGroup>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FROM" />

            <DatePicker
                android:id="@+id/dpCategoryStartDate"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TO" />

            <DatePicker
                android:id="@+id/dpCategoryEndDate"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

        </LinearLayout>
    </LinearLayout>
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_weight="100"/>
    <ListView
        android:id="@+id/lvCategories"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="500"/>
    <Button
        android:id="@+id/btnAddCategory"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="100"
        android:text="Add SubCategory"
        android:textAllCaps="true"/>


</LinearLayout>