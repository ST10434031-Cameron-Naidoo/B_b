<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/main_bg_gradient">

    <TextView
        android:id="@+id/tvGoalsHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="GOALS"
        android:textColor="@color/white"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/layoutFilters"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/rounded_dark_blue_box"
        android:padding="12dp"
        android:baselineAligned="false"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/tvGoalsHeader">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SORT BY:"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:textStyle="bold"/>
            <RadioGroup
                android:id="@+id/rgSortHome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <RadioButton android:id="@+id/rbAZ" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="A-Z" android:textColor="@color/white" android:textSize="12sp" android:buttonTint="@color/white"/>
                <RadioButton android:id="@+id/rbFirstAdded" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="First Added" android:textColor="@color/white" android:textSize="12sp" android:buttonTint="@color/white"/>
                <RadioButton android:id="@+id/rbLastAdded" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Last Added" android:textColor="@color/white" android:textSize="12sp" android:buttonTint="@color/white"/>
            </RadioGroup>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FROM:"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:textStyle="bold"/>
            <TextView android:id="@+id/tvDateFrom" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="10 - 06 - 2026 ⌵" android:textColor="@color/white" android:textSize="12sp" android:paddingVertical="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TO:"
                android:layout_marginTop="8dp"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:textStyle="bold"/>
            <TextView android:id="@+id/tvDateTo" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="10 - 07 - 2026 ⌵" android:textColor="@color/white" android:textSize="12sp" android:paddingVertical="4dp"/>
        </LinearLayout>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvGoalsList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:clipToPadding="false"
        android:paddingBottom="100dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutFilters" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAddNewGoal"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:layout_margin="24dp"
        android:text="ADD GOAL     +"
        android:textSize="20sp"
        android:textStyle="bold"
        app:backgroundTint="@color/accent_dark_blue"
        app:cornerRadius="15dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>